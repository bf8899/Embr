# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only: bypasses RLS (Mux webhook marks videos ready). Never expose.
SUPABASE_SERVICE_ROLE_KEY=

# Video provider: 'mux' routes new uploads through Mux; else the storage stub.
VIDEO_PROVIDER=mux
MUX_TOKEN_ID=
MUX_TOKEN_SECRET=
MUX_WEBHOOK_SECRET=

# Google AdSense (display ads). Leave blank to render ad-slot placeholders.
NEXT_PUBLIC_ADSENSE_CLIENT=
NEXT_PUBLIC_ADSENSE_SLOT=
